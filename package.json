{
	"name": "wisp-server-edu",
	"version": "2.0.0",
	"description": "Mrowisp server",
	"type": "module",
	"engines": {
		"npm": ">=7.0.0",
		"node": ">=16.0.0"
	},
	"scripts": {
		"postinstall": "[ -f node_modules/mrrowisp/dist/config.json ] || cp node_modules/mrrowisp/dist/example.config.json node_modules/mrrowisp/dist/config.json && sed -i 's/\"port\": *\"\\([0-9]*\\)\"/\"port\": \\1/' node_modules/mrrowisp/dist/config.json",
		"dev": "node src/index.js",
		"build": "echo 'No build step' || true",
		"start": "node src/index.js"
	},
	"keywords": [
		"wisp",
		"mrrowisp"
	],
	"author": "Mercury Workshop",
	"license": "GNU AFFERO",
	"dependencies": {
		"@fastify/static": "^8.2.0",
		"@mercuryworkshop/wisp-js": "^0.4.1",
		"fastify": "^5.4.0",
		"mrrowisp": "^1.2.1",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"eslint": "^9.13.0",
		"prettier": "^3.3.3"
	}
}
