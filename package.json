{
	"name": "wisp-server-edu",
	"version": "2.0.0",
	"description": "Mrowisp server",
	"type": "module",
	"engines": {
		"npm": ">=7.0.0",
		"node": ">=16.0.0"
	},
	"scripts": {
		"postinstall": "node -e \"import('fs').then(({existsSync,copyFileSync,readFileSync,writeFileSync})=>{const d='node_modules/mrrowisp/dist/config.json';if(!existsSync(d))copyFileSync('node_modules/mrrowisp/dist/example.config.json',d);const c=JSON.parse(readFileSync(d,'utf-8'));if(typeof c.port==='string')c.port=parseInt(c.port)||6001;writeFileSync(d,JSON.stringify(c,null,2))})\"",
		"dev": "bun src/index.js",
		"build": "echo 'No build step' || true",
		"start": "bun src/index.js"
	},
	"keywords": [
		"wisp",
		"mrrowisp"
	],
	"author": "Mercury Workshop",
	"license": "GNU AFFERO",
	"dependencies": {
		"@fastify/static": "^8.2.0",
		"@mercuryworkshop/wisp-js": "^0.4.1",
		"fastify": "^5.4.0",
		"mrrowisp": "^1.2.1",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"eslint": "^9.13.0",
		"prettier": "^3.3.3"
	}
}
